#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# -----------------------------------------------------------------------------
# init-krusader  –  Krusader Theme & Config Bootstrap
# -----------------------------------------------------------------------------
# Laeuft als s6-Init-Skript NACH init-selkies-config (wo /defaults/autostart
# in /config/.config/openbox/autostart kopiert wird). ACHTUNG Selkies-Base:
# init-selkies-config RESTAURIERT /etc/xdg/openbox/rc.xml bei JEDEM Start aus
# einer .bak und wendet dann NO_DECOR/NO_FULL-seds an - unser Komplett-Override
# in 2d gewinnt trotzdem (wir laufen per Dependency danach), aber die
# Base-Features NO_DECOR/NO_FULL wirken auf UNSERE rc.xml nicht.
#
# WARUM SO KOMPLEX:
# Krusader ist eine KDE-Frameworks-App. KDE-Apps benutzen die "KColorScheme"-
# Engine, die nur funktioniert, wenn:
#   (a) das Qt-Plattform-Theme-Plugin "kde" geladen wird
#       (geliefert vom Paket plasma-integration, libkdeplatformtheme.so)
#   (b) die Color-Scheme-Datei im offiziellen KDE-Format unter dem Standard-
#       Suchpfad liegt (~/.local/share/color-schemes/ oder
#       /usr/share/color-schemes/)
#   (c) kdeglobals den ColorScheme-Namen referenziert
#   (d) XDG_CURRENT_DESKTOP=KDE gesetzt ist, sonst greift das KDE-Plugin nicht
#
# qt5ct funktioniert NICHT mit KDE-.colors-Files — qt5ct hat ein anderes
# Format (single-line active_colors=#aarrggbb,...) und liefert bei einer
# KDE-Datei eine leere weisse Default-Palette zurueck. Genau das hat zur
# hellen UI mit Linien-Optik gefuehrt.
# -----------------------------------------------------------------------------
set -e

log() { echo "[init-krusader] $*"; }

# -- Theme selection (KRUSADER_THEME = dark | light) --------------------------
# Everything that differs between the two themes is derived ONCE here so the
# whole script stays consistent. dark = our Dark Mode (Carbon greyscale, shipped
# as DarkMode.colors); light = KDE Breeze Light (shipped by the 'breeze' /
# 'plasma-workspace' packages at /usr/share/color-schemes/BreezeLight.colors).
# This MUST drive the palette merge below — merging the dark palette regardless
# of KRUSADER_THEME is what previously made light mode stay dark.
case "${KRUSADER_THEME:-dark}" in
    light)
        THEME_SCHEME="BreezeLight"; THEME_NAME="Breeze Light"
        THEME_LNF="org.kde.breeze.desktop"
        THEME_COLORS="/usr/share/color-schemes/BreezeLight.colors"
        THEME_GTK="Breeze"; THEME_ICONS="breeze"; THEME_KATE="Breeze Light"
        ;;
    *)
        THEME_SCHEME="DarkMode"; THEME_NAME="Dark Mode"
        THEME_LNF="org.kde.breezedark.desktop"
        THEME_COLORS="/defaults/color-schemes/DarkMode.colors"
        THEME_GTK="Breeze-Dark"; THEME_ICONS="breeze-dark"; THEME_KATE="Dark Mode"
        ;;
esac

# The house ASCII brand banner is printed later, right above the "KRUSADER IS
# READY" box (see svc-krusader-ready/run), so brand + ready status sit together
# as the log's final block instead of scrolling off the top during startup.

# -- 1) ENV-Propagation via s6 ------------------------------------------------
# /run/s6/container_environment/<NAME>=<VALUE> ist der offizielle Weg, ENV in
# alle s6-Services zu injizieren. Jedes File = eine Variable.
mkdir -p /run/s6/container_environment

set_env() {
    printf "%s" "$2" > "/run/s6/container_environment/$1"
}

# *** KERN-FIX: KDE-Plattform-Theme-Plugin aktivieren ***
# QT_QPA_PLATFORMTHEME=kde + XDG_CURRENT_DESKTOP=KDE laed das Plugin
# libkdeplatformtheme.so aus plasma-integration. Das Plugin liest dann
# kdeglobals direkt UND kennt das KDE-.colors-Format.
set_env QT_QPA_PLATFORMTHEME      "kde"
set_env XDG_CURRENT_DESKTOP       "KDE"
set_env XDG_SESSION_DESKTOP       "KDE"
set_env DESKTOP_SESSION           "plasma"

# QT_STYLE_OVERRIDE=Breeze sorgt dafuer, dass auch Qt-Apps OHNE KDE-Plugin
# (hypothetisch) den Breeze-Style verwenden.
set_env QT_STYLE_OVERRIDE         "Breeze"
set_env QT_AUTO_SCREEN_SCALE_FACTOR "1"

# Pfad zum Color-Scheme — KDE-Plugin findet es ueber kdeglobals,
# Variable als zusaetzlicher Hint.
set_env KDE_COLOR_SCHEME_PATH     "/usr/share/color-schemes/${THEME_SCHEME}.colors"

# GTK + Cursor + Icons (fuer GTK-Dialoge, die Krusader z.B. fuer Datei-
# Operationen oeffnet).
set_env GTK_THEME                 "${THEME_GTK}"
set_env XCURSOR_THEME             "breeze_cursors"
set_env ICON_THEME                "${THEME_ICONS}"

log "ENV in /run/s6/container_environment gesetzt (KDE-Plugin-Mode)"

# -- 2) Theme-/Config-Files (immer frisch) ------------------------------------
DEFAULTS="/defaults"
CONFIG_HOME="/config/.config"
LOCAL_SHARE="/config/.local/share"
USER_COLOR_SCHEMES="${LOCAL_SHARE}/color-schemes"
SYSTEM_COLOR_SCHEMES="/usr/share/color-schemes"
KDEDEFAULTS="${CONFIG_HOME}/kdedefaults"

mkdir -p "${CONFIG_HOME}/qt5ct" \
         "${CONFIG_HOME}/qt6ct" \
         "${CONFIG_HOME}/openbox" \
         "${KDEDEFAULTS}" \
         "${USER_COLOR_SCHEMES}" \
         "${LOCAL_SHARE}/krusader" \
         "${SYSTEM_COLOR_SCHEMES}"

LOCK="/config/.krusader-firstrun.done"

# 2a) User-geschuetzt: nur First-Run
if [[ ! -f "${LOCK}" ]]; then
    log "First-run – seeding user-editable defaults"
    [[ ! -e "${CONFIG_HOME}/krusaderrc"      ]] && cp -a "${DEFAULTS}/krusaderrc"      "${CONFIG_HOME}/krusaderrc"
    [[ ! -e "${CONFIG_HOME}/katerc"          ]] && cp -a "${DEFAULTS}/katerc"          "${CONFIG_HOME}/katerc"
    [[ ! -e "${LOCAL_SHARE}/krusader/useractions.xml" ]] && cp -a "${DEFAULTS}/useractions.xml.template" "${LOCAL_SHARE}/krusader/useractions.xml"
    touch "${LOCK}"
fi

# 2a-bis) Idempotenter Key-Injector fuer krusaderrc.
# Krusader generiert beim allerersten Programmstart selbst eine krusaderrc,
# bevor unser First-Run-cp greifen kann (Race auf den ersten WebUI-Open).
# Damit fehlen kritische Keys (Statusleiste/Fenstergroesse persistieren),
# auch nach Image-Update. Wir injizieren sie hier idempotent — bestehende
# User-Werte werden NICHT ueberschrieben.
ensure_ini_key() {
    local file="$1" section="$2" key="$3" value="$4"
    [[ -f "$file" ]] || return 0
    # Section vorhanden?
    if ! grep -qE "^\[${section}\]" "$file"; then
        printf '\n[%s]\n%s=%s\n' "$section" "$key" "$value" >> "$file"
        return 0
    fi
    # Key in Section vorhanden?
    if awk -v s="[${section}]" -v k="$key" '
        $0==s {in_s=1; next}
        /^\[/ && in_s {in_s=0}
        in_s && $0 ~ "^"k"=" {found=1; exit}
        END {exit !found}
    ' "$file"; then
        return 0
    fi
    # Key fehlt -> direkt nach Section-Header einfuegen
    sed -i "/^\[${section}\]/a ${key}=${value}" "$file"
}

if [[ -f "${CONFIG_HOME}/krusaderrc" ]]; then
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Remember Position"   "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "User Save Settings"  "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show splashscreen"   "false"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show statusbar"      "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show Cmd Line"       "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show Function Keys"  "true"
    log "krusaderrc: Startup-Keys idempotent gesichert"
    # Hide statusbar + command line by default. IMPORTANT: krusader only
    # RESPECTS the Show statusbar / Show Cmd Line settings when "User Save
    # Settings" is ON (with it OFF it ignores them and shows the bars). So keep
    # it ON and FORCE the two bars off here. The container never gives krusader
    # a clean exit, so save-on-exit can't re-enable them; these forced values
    # win on every start, so the bars stay hidden.
    sed -i 's|^User Save Settings=.*|User Save Settings=true|'  "${CONFIG_HOME}/krusaderrc"
    sed -i 's|^Show statusbar=.*|Show statusbar=false|'         "${CONFIG_HOME}/krusaderrc"
    sed -i 's|^Show Cmd Line=.*|Show Cmd Line=false|'           "${CONFIG_HOME}/krusaderrc"
    log "krusaderrc: statusbar + command line forced hidden (User Save Settings=true)"
fi

# 2b) Theme-Infrastruktur: jeden Start frisch
log "Theme-Infrastruktur (re)deploy"
cp -af "${DEFAULTS}/kdeglobals"                      "${CONFIG_HOME}/kdeglobals"
cp -af "${DEFAULTS}/kdeglobals"                      "${KDEDEFAULTS}/kdeglobals"

# Merge the colour sections from the SELECTED scheme INTO kdeglobals. KColorScheme
# (plasma-integration + the Breeze widget style) builds the Qt palette and the
# View focus/hover decoration — the file-panel frame — from kdeglobals' [Colors:*]
# groups; a separate .colors file alone is NOT read for the palette. This MUST be
# theme-aware: merging the dark palette regardless of KRUSADER_THEME is exactly
# what made light mode stay dark.
if [[ -f "${THEME_COLORS}" ]]; then
    _colors="$(awk '/^\[General\]/{exit} /^\[Color/{p=1} p{print}' "${THEME_COLORS}")"
    for _kg in "${CONFIG_HOME}/kdeglobals" "${KDEDEFAULTS}/kdeglobals"; do
        printf '\n%s\n' "${_colors}" >> "${_kg}"
    done
    log "kdeglobals: [Colors:*] merged from ${THEME_COLORS##*/} (palette source)"
else
    log "WARNING: palette source ${THEME_COLORS} not found — colours may be wrong"
fi

# Color-Scheme an BEIDE Pfade ausrollen — User UND System.
# KDE-Plugin sucht in dieser Reihenfolge:
#   1. ~/.local/share/color-schemes/<Name>.colors
#   2. /usr/share/color-schemes/<Name>.colors
if [[ -f "${DEFAULTS}/color-schemes/DarkMode.colors" ]]; then
    cp -af "${DEFAULTS}/color-schemes/DarkMode.colors" "${USER_COLOR_SCHEMES}/DarkMode.colors"
    cp -af "${DEFAULTS}/color-schemes/DarkMode.colors" "${SYSTEM_COLOR_SCHEMES}/DarkMode.colors" 2>/dev/null || true
fi

# qt5ct/qt6ct nur als Fallback — wir setzen QT_QPA_PLATFORMTHEME=kde, aber
# falls das Plugin mal nicht laedt (z.B. fehlendes plasma-integration in
# einer abgespeckten Variante), greift qt5ct mit eigenem Format.
if [[ -f "${DEFAULTS}/qt5ct.conf" ]]; then
    cp -af "${DEFAULTS}/qt5ct.conf" "${CONFIG_HOME}/qt5ct/qt5ct.conf"
    cp -af "${DEFAULTS}/qt5ct.conf" "${CONFIG_HOME}/qt6ct/qt6ct.conf"
fi
# qt5ct-eigenes Color-Scheme-Format (anders als KDE!)
mkdir -p "${CONFIG_HOME}/qt5ct/colors" "${CONFIG_HOME}/qt6ct/colors"
if [[ -f "${DEFAULTS}/qt5ct-colors/DarkMode.conf" ]]; then
    cp -af "${DEFAULTS}/qt5ct-colors/DarkMode.conf" "${CONFIG_HOME}/qt5ct/colors/DarkMode.conf"
    cp -af "${DEFAULTS}/qt5ct-colors/DarkMode.conf" "${CONFIG_HOME}/qt6ct/colors/DarkMode.conf"
fi

# Kate editor "Dark Mode" syntax theme (Carbon greyscale). KTextEditor reads
# custom themes from $XDG_DATA_HOME/org.kde.syntax-highlighting/themes/; katerc
# selects it via "Color Theme=Dark Mode".
if [[ -f "${DEFAULTS}/syntax-themes/DarkMode.theme" ]]; then
    mkdir -p "${LOCAL_SHARE}/org.kde.syntax-highlighting/themes"
    cp -af "${DEFAULTS}/syntax-themes/DarkMode.theme" "${LOCAL_SHARE}/org.kde.syntax-highlighting/themes/DarkMode.theme"
    log "Kate Dark Mode syntax theme deployed"
fi

# 2c) openbox/autostart IMMER ueberschreiben
cp -af "${DEFAULTS}/autostart" "${CONFIG_HOME}/openbox/autostart"
chmod 0755 "${CONFIG_HOME}/openbox/autostart"

# 2d) openbox rc.xml ueberschreiben — entfernt den LinuxServer-baseimage-Patch
# der jedes Fenster (auch Dialoge wie "Datei loeschen?") maximiert oeffnet.
# Wir wollen, dass Dialoge in ihrer natuerlichen / zuletzt verwendeten Groesse
# erscheinen, nicht bildschirmfuellend.
if [[ -f "${DEFAULTS}/openbox-rc.xml" ]]; then
    install -m 0644 "${DEFAULTS}/openbox-rc.xml" /etc/xdg/openbox/rc.xml
    log "openbox rc.xml overridden (no force-maximize for dialogs)"
fi

# -- 3) Sprache & Theme-Switch (env-driven, idempotent) -----------------------
/usr/local/bin/krusader-language.sh "${KRUSADER_LANG:-de}" || log "language hook failed"

# Propagate locale into s6 container environment so every process
# (krusader, kate, KIO workers) inherits the correct LANG/LC_ALL.
# krusader-language.sh writes the values to a profile snippet; we read
# them back here and push them via set_env so they override the static
# Docker-ENV defaults (e.g. LANG=de_DE.UTF-8).
if [[ -f /config/.profile.d/krusader-lang.sh ]]; then
    _L=$(grep  '^export LANG='     /config/.profile.d/krusader-lang.sh | head -1 | cut -d= -f2-)
    _A=$(grep  '^export LC_ALL='   /config/.profile.d/krusader-lang.sh | head -1 | cut -d= -f2-)
    _C=$(grep  '^export LANGUAGE=' /config/.profile.d/krusader-lang.sh | head -1 | cut -d= -f2-)
    [[ -n "$_L" ]] && set_env LANG     "$_L"
    [[ -n "$_A" ]] && set_env LC_ALL   "$_A"
    [[ -n "$_C" ]] && set_env LANGUAGE "$_C"
    log "Locale -> s6 env: LANG=${_L:-unchanged}"
fi

# Apply the selected scheme name / look-and-feel / Kate theme. The matching
# [Colors:*] palette was already merged into kdeglobals above.
sed -i "s/^ColorScheme=.*/ColorScheme=${THEME_SCHEME}/"             "${CONFIG_HOME}/kdeglobals" || true
sed -i "s/^Name=.*/Name=${THEME_NAME}/"                            "${CONFIG_HOME}/kdeglobals" || true
sed -i "s/^LookAndFeelPackage=.*/LookAndFeelPackage=${THEME_LNF}/"  "${CONFIG_HOME}/kdeglobals" || true
# [Icons] Theme MUST follow the selected theme too — the shipped kdeglobals
# hardcodes breeze-dark, so without this sed EVERY icon (file list AND status
# bar) kept its dark-theme tint under KRUSADER_THEME=light and never "switched".
sed -i "s/^Theme=.*/Theme=${THEME_ICONS}/"                          "${CONFIG_HOME}/kdeglobals" || true
sed -i "s/^Theme=.*/Theme=${THEME_ICONS}/"                          "${KDEDEFAULTS}/kdeglobals" || true
sed -i "s/^ColorScheme=.*/ColorScheme=${THEME_SCHEME}/"             "${CONFIG_HOME}/krusaderrc"  || true
if [[ -f "${CONFIG_HOME}/katerc" ]]; then
    sed -i "s/^Color Theme=.*/Color Theme=${THEME_KATE}/"          "${CONFIG_HOME}/katerc" || true
    sed -i "s/^Schema=.*/Schema=${THEME_KATE}/"                    "${CONFIG_HOME}/katerc" || true
fi

# 2b-ter) MediaButton-Icon folgt der KONFIGURIERTEN Statusleisten-Farbe (#22).
# Der Geraete-Button sitzt auf Krusaders Statusleiste, deren Farben der User
# frei einstellt (Konfigurator -> Farben, krusaderrc [Colors] "Statusbar
# Foreground/Background Active"). KIconLoader toent currentColor-Icons aber aus
# der GLOBALEN Palette, die von dieser lokalen Balkenfarbe nichts weiss — auf
# einem hell konfigurierten Balken blieb das Icon hell. Darum brennen wir hier
# bei jedem Start die konfigurierte Statusbar-VORDERGRUNDFARBE (die Farbe, in
# der der Balken-Text ohnehin steht — also garantiert lesbar) fest ins Icon,
# aus den unberuehrten Build-Kopien. Farbwechsel im Konfigurator greifen beim
# naechsten Container-Start. Fixierter Fill + umbenannte Stylesheet-Id, damit
# KIconLoader nicht wieder aus der Palette uebertoent.
MB_STORE="/usr/local/share/krusader-mediabutton"
if [[ -d "${MB_STORE}" ]]; then
    FG_RGB="$(grep -m1 '^Statusbar Foreground Active=' "${CONFIG_HOME}/krusaderrc" 2>/dev/null | cut -d= -f2 | tr -d '[:space:]')"
    FG_HEX=""
    if [[ "${FG_RGB}" =~ ^([0-9]{1,3}),([0-9]{1,3}),([0-9]{1,3})$ ]]; then
        FG_HEX="$(printf '#%02x%02x%02x' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}")"
    fi
    if [[ -z "${FG_HEX}" ]]; then
        [[ "${KRUSADER_THEME:-dark}" == "light" ]] && FG_HEX="#232629" || FG_HEX="#f4f4f4"
    fi
    mb_n=0
    for mb_src in "${MB_STORE}"/*/*.svg; do
        [[ -e "${mb_src}" ]] || continue
        mb_theme="$(basename "$(dirname "${mb_src}")")"
        mb_sz="$(basename "${mb_src}" .svg)"
        mb_dst="/usr/share/icons/${mb_theme}/apps/${mb_sz}/system-file-manager.svg"
        [[ -d "$(dirname "${mb_dst}")" ]] || continue
        sed -e "s/currentColor/${FG_HEX}/g" \
            -e 's/id="current-color-scheme"/id="frozen-color-scheme"/' \
            "${mb_src}" > "${mb_dst}"
        mb_n=$((mb_n + 1))
    done
    log "MediaButton-Icon auf Statusbar-Foreground ${FG_HEX} getoent (${mb_n} Dateien)"
fi

# 2b-quater) DATEILISTEN-Ordner-Icons folgen der konfigurierten Listen-Farbe.
# Gleicher Mechanismus wie der MediaButton, nur mit der Panel-Farbe aus dem
# Konfigurator (krusaderrc [Colors]): bevorzugt "Directory Foreground"
# (Krusaders eigene Ordner-Textfarbe), sonst "Foreground" (Standard-Text).
# Ist eine gesetzt, wird sie in places/<sz>/folder.svg eingebrannt (die
# inode-directory-Symlinks der Liste zeigen genau dorthin). Ohne eigene Farbe
# werden die unberuehrten Build-Kopien restauriert (Stock: Palette/Theme).
# Section-scoped: Keys nur aus [Colors] lesen; leere Werte (Key ohne Wert,
# schreibt der Konfigurator fuer "Default") zaehlen als nicht gesetzt.
PF_STORE="/usr/local/share/krusader-panelfolder"
if [[ -d "${PF_STORE}" ]]; then
    PF_RGB="$(sed -n '/^\[Colors\]/,/^\[/{s/^Directory Foreground=//p}' "${CONFIG_HOME}/krusaderrc" 2>/dev/null | head -1 | tr -d '[:space:]')"
    if [[ -z "${PF_RGB}" ]]; then
        PF_RGB="$(sed -n '/^\[Colors\]/,/^\[/{s/^Foreground=//p}' "${CONFIG_HOME}/krusaderrc" 2>/dev/null | head -1 | tr -d '[:space:]')"
    fi
    PF_HEX=""
    if [[ "${PF_RGB}" =~ ^([0-9]{1,3}),([0-9]{1,3}),([0-9]{1,3})$ ]]; then
        PF_HEX="$(printf '#%02x%02x%02x' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}")"
    fi
    pf_n=0
    for pf_src in "${PF_STORE}"/*/*.svg; do
        [[ -e "${pf_src}" ]] || continue
        pf_theme="$(basename "$(dirname "${pf_src}")")"
        pf_sz="$(basename "${pf_src}" .svg)"
        pf_dst="/usr/share/icons/${pf_theme}/places/${pf_sz}/folder.svg"
        [[ -e "${pf_dst}" ]] || continue
        if [[ -n "${PF_HEX}" ]]; then
            sed -e "s/currentColor/${PF_HEX}/g" \
                -e 's/id="current-color-scheme"/id="frozen-color-scheme"/' \
                "${pf_src}" > "${pf_dst}"
        else
            cp -f "${pf_src}" "${pf_dst}"
        fi
        pf_n=$((pf_n + 1))
    done
    if [[ -n "${PF_HEX}" ]]; then
        log "Dateilisten-Ordner-Icons auf Panel-Foreground ${PF_HEX} getoent (${pf_n} Dateien)"
    else
        log "Dateilisten-Ordner-Icons: keine eigene Panel-Farbe gesetzt — Stock-Icons restauriert (${pf_n})"
    fi
fi

# 2c) File associations (Issue #22): register Kate as the default text handler so
# a double-click opens Kate DIRECTLY instead of the "Open With" dialog, and Kate
# is offered in Open With. Deployed to the XDG config-home AND the legacy
# data-home applications dir; the kbuildsycoca6 rebuild below bakes it into
# KSycoca. Deployed on EVERY start (not first-run) so existing /config installs
# get the fix too.
if [[ -f "${DEFAULTS}/mimeapps.list" ]]; then
    cp -af "${DEFAULTS}/mimeapps.list" "${CONFIG_HOME}/mimeapps.list"
    mkdir -p "${LOCAL_SHARE}/applications"
    cp -af "${DEFAULTS}/mimeapps.list" "${LOCAL_SHARE}/applications/mimeapps.list"
    log "mimeapps.list deployed (text/* default -> Kate)"
fi

# Permissions
chown -R abc:abc /config/.config /config/.local 2>/dev/null || true

# -- 3b) KService-Cache (kbuildsycoca6) fuer "Open With..." (Issue #22) -------
# KOpenWithDialog (Rechtsklick -> "Oeffnen mit...") wird NICHT aus den .desktop-
# Dateien direkt gefuellt, sondern aus KSycoca — einem binaeren Cache, den
# KApplicationTrader abfragt. In einer vollen Plasma-Session baut kded6 diesen
# Cache beim eigenen Start automatisch auf (kded6(8): "Those tasks are also
# run when kded6 is started to ensure that the user configuration is up to
# date."). Dieses Image faehrt openbox statt Plasma; kded6 wird hier bestenfalls
# spaet und beilaeufig per D-Bus-Aktivierung gestartet, wenn zufaellig ein KIO-
# Call es ausloest (im Box-Test beobachtet, siehe Kommentar in defaults/autostart:
# "Doppel-kded/KIO-Effekte") — es gibt aber KEINE Garantie, dass das VOR dem
# ersten "Oeffnen mit..." des Users passiert ist. Ohne fertigen Cache liefert
# KApplicationTrader eine leere Liste: KOpenWithDialog zeigt dann eine KOMPLETT
# leere Anwendungsliste UND eine leere Text-Combobox — nicht nur "Kate fehlt".
# Gleiches, dokumentiertes Verhalten ausserhalb einer vollen KDE-Session ist
# u.a. fuer Dolphin unter Hyprland belegt (kbuildsycoca6 manuell noetig, bis
# die Anwendungsliste wieder Eintraege zeigt).
# kbuildsycoca6 selbst baut den Cache SYNCHRON im aufrufenden Prozess (kein
# Daemon/D-Bus-Umweg noetig, siehe KService-Quellcode), ist bei unveraenderten
# .desktop-Verzeichnissen ein guenstiger No-Op, und liegt bereits im Image
# (libkf6service-bin, Pflichtabhaengigkeit von plasma-workspace/kde-cli-tools).
# Wir bauen ihn hier proaktiv bei JEDEM Start, ALS abc (damit der Cache unter
# $HOME/.cache abc-gehoert ist, genau wie alles andere, was Krusader/Kate
# selbst als abc anlegen) — das schliesst die Race komplett, statt auf die
# zufaellige kded-Aktivierung zu hoffen.
mkdir -p /config/.cache
chown abc:abc /config/.cache
# Purge the stale KF5 ksycoca5_* leftover — KF6 krusader only reads ksycoca6_*.
rm -f /config/.cache/ksycoca5_* 2>/dev/null || true
# Purge KIconLoader's shared pixmap cache: it persists in the /config volume
# across image updates and keeps serving the OLD pixmap keyed to the previous
# icon files, so a changed system-file-manager (= folder) icon would look like a
# no-op ("nothing changed"). gtk-update-icon-cache does NOT touch this KDE cache.
# KIconLoader rebuilds it lazily on next start.
rm -f /config/.cache/icon-cache.kcache 2>/dev/null || true
# HOME/XDG_CACHE_HOME explizit: s6-setuidgid wechselt nur uid/gid, NICHT das
# Environment — der Cache MUSS unter /config/.cache landen (persistent, dort
# sucht ihn Krusader-als-abc), nicht unter einem geerbten Root-HOME.
if command -v kbuildsycoca6 >/dev/null 2>&1; then
    if env HOME=/config XDG_CACHE_HOME=/config/.cache s6-setuidgid abc kbuildsycoca6 --noincremental >/tmp/kbuildsycoca6.log 2>&1; then
        log "kbuildsycoca6: KService-Cache aufgebaut (Open With.../KApplicationTrader)"
    else
        log "WARNING: kbuildsycoca6 ist fehlgeschlagen — 'Oeffnen mit...' bleibt evtl. leer (siehe /tmp/kbuildsycoca6.log)"
    fi
else
    log "WARNING: kbuildsycoca6 nicht gefunden — 'Oeffnen mit...' zeigt eine leere Liste (Issue #22)"
fi

# -- 4) Diagnose-Output -------------------------------------------------------
log "=== Diagnose ==="
log "ColorScheme in kdeglobals: $(grep -E '^ColorScheme=' "${CONFIG_HOME}/kdeglobals" | head -n 1)"
log "theme=${KRUSADER_THEME:-dark} scheme=${THEME_SCHEME}; palette source ${THEME_COLORS} ($(ls -la "${THEME_COLORS}" 2>/dev/null | awk '{print $5}') bytes)"
log "kde-plattform-plugin: $(find /usr/lib -name 'libkdeplatformtheme.so' 2>/dev/null | head -n 1 || echo NOT-FOUND)"
log "breeze-style-plugin:  $(find /usr/lib -name 'breeze.so' -path '*styles*' 2>/dev/null | head -n 1 || echo NOT-FOUND)"
log "fc-list count:        $(fc-list 2>/dev/null | wc -l)"
log "kbuildsycoca6 cache:  $(find /config/.cache -iname '*sycoca*' 2>/dev/null | head -n 1 || echo NOT-FOUND)"

log "init-krusader done"
exit 0
