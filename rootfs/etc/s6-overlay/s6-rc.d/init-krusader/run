#!/usr/bin/with-contenv bash
# -----------------------------------------------------------------------------
# init-krusader  –  Krusader Theme & Config Bootstrap
# -----------------------------------------------------------------------------
# Laeuft als s6-Init-Skript NACH init-kasmvnc-config (wo /defaults/autostart
# in /config/.config/openbox/autostart kopiert wird).
#
# WARUM SO KOMPLEX:
# Krusader ist eine KDE-Frameworks-App. KDE-Apps benutzen die "KColorScheme"-
# Engine, die nur funktioniert, wenn:
#   (a) das Qt-Plattform-Theme-Plugin "kde" geladen wird
#       (geliefert vom Paket plasma-integration, libkdeplatformtheme.so)
#   (b) die Color-Scheme-Datei im offiziellen KDE-Format unter dem Standard-
#       Suchpfad liegt (~/.local/share/color-schemes/ oder
#       /usr/share/color-schemes/)
#   (c) kdeglobals den ColorScheme-Namen referenziert
#   (d) XDG_CURRENT_DESKTOP=KDE gesetzt ist, sonst greift das KDE-Plugin nicht
#
# qt5ct funktioniert NICHT mit KDE-.colors-Files — qt5ct hat ein anderes
# Format (single-line active_colors=#aarrggbb,...) und liefert bei einer
# KDE-Datei eine leere weisse Default-Palette zurueck. Genau das hat zur
# hellen UI mit Linien-Optik gefuehrt.
# -----------------------------------------------------------------------------
set -e

log() { echo "[init-krusader] $*"; }

# -- 1) ENV-Propagation via s6 ------------------------------------------------
# /run/s6/container_environment/<NAME>=<VALUE> ist der offizielle Weg, ENV in
# alle s6-Services zu injizieren. Jedes File = eine Variable.
mkdir -p /run/s6/container_environment

set_env() {
    printf "%s" "$2" > "/run/s6/container_environment/$1"
}

# *** KERN-FIX: KDE-Plattform-Theme-Plugin aktivieren ***
# QT_QPA_PLATFORMTHEME=kde + XDG_CURRENT_DESKTOP=KDE laed das Plugin
# libkdeplatformtheme.so aus plasma-integration. Das Plugin liest dann
# kdeglobals direkt UND kennt das KDE-.colors-Format.
set_env QT_QPA_PLATFORMTHEME      "kde"
set_env XDG_CURRENT_DESKTOP       "KDE"
set_env XDG_SESSION_DESKTOP       "KDE"
set_env DESKTOP_SESSION           "plasma"

# QT_STYLE_OVERRIDE=Breeze sorgt dafuer, dass auch Qt-Apps OHNE KDE-Plugin
# (hypothetisch) den Breeze-Style verwenden.
set_env QT_STYLE_OVERRIDE         "Breeze"
set_env QT_AUTO_SCREEN_SCALE_FACTOR "1"

# Pfad zum Color-Scheme — KDE-Plugin findet es ueber kdeglobals,
# Variable als zusaetzlicher Hint.
set_env KDE_COLOR_SCHEME_PATH     "/usr/share/color-schemes/BreezeDark.colors"

# GTK + Cursor + Icons (fuer GTK-Dialoge, die Krusader z.B. fuer Datei-
# Operationen oeffnet).
set_env GTK_THEME                 "Breeze-Dark"
set_env XCURSOR_THEME             "breeze_cursors"
set_env ICON_THEME                "breeze-dark"

log "ENV in /run/s6/container_environment gesetzt (KDE-Plugin-Mode)"

# -- 2) Theme-/Config-Files (immer frisch) ------------------------------------
DEFAULTS="/defaults"
CONFIG_HOME="/config/.config"
LOCAL_SHARE="/config/.local/share"
USER_COLOR_SCHEMES="${LOCAL_SHARE}/color-schemes"
SYSTEM_COLOR_SCHEMES="/usr/share/color-schemes"
KDEDEFAULTS="${CONFIG_HOME}/kdedefaults"

mkdir -p "${CONFIG_HOME}/qt5ct" \
         "${CONFIG_HOME}/qt6ct" \
         "${CONFIG_HOME}/openbox" \
         "${KDEDEFAULTS}" \
         "${USER_COLOR_SCHEMES}" \
         "${LOCAL_SHARE}/krusader" \
         "${SYSTEM_COLOR_SCHEMES}"

LOCK="/config/.krusader-firstrun.done"

# 2a) User-geschuetzt: nur First-Run
if [[ ! -f "${LOCK}" ]]; then
    log "First-run – seeding user-editable defaults"
    [[ ! -e "${CONFIG_HOME}/krusaderrc"      ]] && cp -a "${DEFAULTS}/krusaderrc"      "${CONFIG_HOME}/krusaderrc"
    [[ ! -e "${CONFIG_HOME}/katerc"          ]] && cp -a "${DEFAULTS}/katerc"          "${CONFIG_HOME}/katerc"
    [[ ! -e "${LOCAL_SHARE}/krusader/useractions.xml" ]] && cp -a "${DEFAULTS}/useractions.xml.template" "${LOCAL_SHARE}/krusader/useractions.xml"
    touch "${LOCK}"
fi

# 2a-bis) Idempotenter Key-Injector fuer krusaderrc.
# Krusader generiert beim allerersten Programmstart selbst eine krusaderrc,
# bevor unser First-Run-cp greifen kann (Race auf den ersten WebUI-Open).
# Damit fehlen kritische Keys (Statusleiste/Fenstergroesse persistieren),
# auch nach Image-Update. Wir injizieren sie hier idempotent — bestehende
# User-Werte werden NICHT ueberschrieben.
ensure_ini_key() {
    local file="$1" section="$2" key="$3" value="$4"
    [[ -f "$file" ]] || return 0
    # Section vorhanden?
    if ! grep -qE "^\[${section}\]" "$file"; then
        printf '\n[%s]\n%s=%s\n' "$section" "$key" "$value" >> "$file"
        return 0
    fi
    # Key in Section vorhanden?
    if awk -v s="[${section}]" -v k="$key" '
        $0==s {in_s=1; next}
        /^\[/ && in_s {in_s=0}
        in_s && $0 ~ "^"k"=" {found=1; exit}
        END {exit !found}
    ' "$file"; then
        return 0
    fi
    # Key fehlt -> direkt nach Section-Header einfuegen
    sed -i "/^\[${section}\]/a ${key}=${value}" "$file"
}

if [[ -f "${CONFIG_HOME}/krusaderrc" ]]; then
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Remember Position"   "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "User Save Settings"  "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show splashscreen"   "false"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show statusbar"      "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show Cmd Line"       "true"
    ensure_ini_key "${CONFIG_HOME}/krusaderrc" "Startup" "Show Function Keys"  "true"
    log "krusaderrc: Startup-Keys idempotent gesichert"
fi

# 2b) Theme-Infrastruktur: jeden Start frisch
log "Theme-Infrastruktur (re)deploy"
cp -af "${DEFAULTS}/kdeglobals"                      "${CONFIG_HOME}/kdeglobals"
cp -af "${DEFAULTS}/kdeglobals"                      "${KDEDEFAULTS}/kdeglobals"

# Color-Scheme an BEIDE Pfade ausrollen — User UND System.
# KDE-Plugin sucht in dieser Reihenfolge:
#   1. ~/.local/share/color-schemes/<Name>.colors
#   2. /usr/share/color-schemes/<Name>.colors
if [[ -f "${DEFAULTS}/color-schemes/BreezeDark.colors" ]]; then
    cp -af "${DEFAULTS}/color-schemes/BreezeDark.colors" "${USER_COLOR_SCHEMES}/BreezeDark.colors"
    cp -af "${DEFAULTS}/color-schemes/BreezeDark.colors" "${SYSTEM_COLOR_SCHEMES}/BreezeDark.colors" 2>/dev/null || true
fi

# qt5ct/qt6ct nur als Fallback — wir setzen QT_QPA_PLATFORMTHEME=kde, aber
# falls das Plugin mal nicht laedt (z.B. fehlendes plasma-integration in
# einer abgespeckten Variante), greift qt5ct mit eigenem Format.
if [[ -f "${DEFAULTS}/qt5ct.conf" ]]; then
    cp -af "${DEFAULTS}/qt5ct.conf" "${CONFIG_HOME}/qt5ct/qt5ct.conf"
    cp -af "${DEFAULTS}/qt5ct.conf" "${CONFIG_HOME}/qt6ct/qt6ct.conf"
fi
# qt5ct-eigenes Color-Scheme-Format (anders als KDE!)
mkdir -p "${CONFIG_HOME}/qt5ct/colors" "${CONFIG_HOME}/qt6ct/colors"
if [[ -f "${DEFAULTS}/qt5ct-colors/BreezeDark.conf" ]]; then
    cp -af "${DEFAULTS}/qt5ct-colors/BreezeDark.conf" "${CONFIG_HOME}/qt5ct/colors/BreezeDark.conf"
    cp -af "${DEFAULTS}/qt5ct-colors/BreezeDark.conf" "${CONFIG_HOME}/qt6ct/colors/BreezeDark.conf"
fi

# 2c) openbox/autostart IMMER ueberschreiben
cp -af "${DEFAULTS}/autostart" "${CONFIG_HOME}/openbox/autostart"
chmod 0755 "${CONFIG_HOME}/openbox/autostart"

# 2d) openbox rc.xml ueberschreiben — entfernt den LinuxServer-baseimage-Patch
# der jedes Fenster (auch Dialoge wie "Datei loeschen?") maximiert oeffnet.
# Wir wollen, dass Dialoge in ihrer natuerlichen / zuletzt verwendeten Groesse
# erscheinen, nicht bildschirmfuellend.
if [[ -f "${DEFAULTS}/openbox-rc.xml" ]]; then
    install -m 0644 "${DEFAULTS}/openbox-rc.xml" /etc/xdg/openbox/rc.xml
    log "openbox rc.xml overridden (no force-maximize for dialogs)"
fi

# -- 3) Sprache & Theme-Switch (env-driven, idempotent) -----------------------
/usr/local/bin/krusader-language.sh "${KRUSADER_LANG:-de}" || log "language hook failed"

case "${KRUSADER_THEME:-dark}" in
    dark)
        sed -i 's/^ColorScheme=.*/ColorScheme=BreezeDark/'                                "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^Name=.*/Name=Breeze Dark/'                                             "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^LookAndFeelPackage=.*/LookAndFeelPackage=org.kde.breezedark.desktop/'  "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^ColorScheme=.*/ColorScheme=BreezeDark/' "${CONFIG_HOME}/krusaderrc" || true
        ;;
    light)
        sed -i 's/^ColorScheme=.*/ColorScheme=BreezeLight/'                               "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^Name=.*/Name=Breeze Light/'                                            "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^LookAndFeelPackage=.*/LookAndFeelPackage=org.kde.breeze.desktop/'      "${CONFIG_HOME}/kdeglobals" || true
        sed -i 's/^ColorScheme=.*/ColorScheme=BreezeLight/' "${CONFIG_HOME}/krusaderrc" || true
        ;;
esac

# Permissions
chown -R abc:abc /config/.config /config/.local 2>/dev/null || true

# -- 4) Diagnose-Output -------------------------------------------------------
log "=== Diagnose ==="
log "ColorScheme in kdeglobals: $(grep -E '^ColorScheme=' "${CONFIG_HOME}/kdeglobals" | head -n 1)"
log "BreezeDark.colors in user scheme dir: $(ls -la "${USER_COLOR_SCHEMES}/BreezeDark.colors" 2>/dev/null | awk '{print $5}') bytes"
log "BreezeDark.colors in system scheme dir: $(ls -la "${SYSTEM_COLOR_SCHEMES}/BreezeDark.colors" 2>/dev/null | awk '{print $5}') bytes"
log "kde-plattform-plugin: $(find /usr/lib -name 'libkdeplatformtheme.so' 2>/dev/null | head -n 1 || echo NOT-FOUND)"
log "breeze-style-plugin:  $(find /usr/lib -name 'breeze.so' -path '*styles*' 2>/dev/null | head -n 1 || echo NOT-FOUND)"
log "fc-list count:        $(fc-list 2>/dev/null | wc -l)"

log "init-krusader done"
exit 0
