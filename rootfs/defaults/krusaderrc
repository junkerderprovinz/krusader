# Default Krusader-Settings
# Wird beim ersten Start nach /config/.config/krusaderrc kopiert,
# falls dort noch keine Datei existiert. Bestehende User-Configs
# werden NICHT überschrieben.

[General]
Editor=kate
View Font=Noto Sans,10,-1,5,50,0,0,0,0,0
Filelist Font=Noto Sans,10,-1,5,50,0,0,0,0,0
Show hidden files=true
Mark Dirs=false

[Look&Feel]
Filelist Icon Size=22
Single Click Selects=false
Show Hidden Files=true
Mark Dirs=false
Numeric permissions=false
Human Readable Size=true

[Archives]
Do Test Archive=true
Allow Move Into Archive=true
Use Krarc for Archives=true
Test Archives Before Use=true
fallback_extractor=true

[Startup]
Show splashscreen=false
Start To Tray=false
# Save last position, size and panel settings -> Window-Geometrie persistieren
Remember Position=true
# Save component settings on exit -> Statusleiste/Toolbar/Menubar-State
# beim Schliessen persistieren. Ohne diesen Schluessel ignoriert Krusader
# Aenderungen an View > Show Statusbar / Show Toolbar etc. nach dem Neustart.
User Save Settings=true
Show statusbar=true
Show Cmd Line=true
Show Function Keys=true
Show Terminal Emulator=false

[Private]
RememberPos=true

[Colors]
# Krusader's OWN file-panel colours — editable at runtime under
# Settings > Configure Krusader > Colors. We preset ONLY the green accents the
# user can re-edit there; every key left unset inherits the dark KDE colour
# scheme (Qt palette). The app chrome (active-tab line, Konfigurator page nav,
# checkbox marks, menus) is NOT a Krusader colour and is not editable here — it
# stays dark-native grey via the colour scheme's [Colors:Selection].
#
# Gotchas (verified against Krusader's KF6 source, app/Panel/krcolorcache.cpp):
#   * the flag key is "KDE Default" WITH a space — "KDEDefault" is silently
#     ignored, which leaves the flag at its true default and disables every key
#     below, so the space is mandatory.
#   * colour values must be decimal R,G,B; a #hex string has no commas and is
#     discarded.
#   * the scheme itself is applied via kdeglobals + KDE_COLOR_SCHEME_PATH (set by
#     init-krusader), NOT from here, so no ColorScheme= line is needed.
KDE Default=false
# File-list selection = Krusader's "Marked" item: green (Carbon #198038) + near-
# white text. Shown in the dialog as "Selected background / foreground".
Marked Background=25,128,56
Marked Foreground=244,244,244
# Cursor / current row = a subtle grey so the cursor stays visible on the dark
# base and reads as distinct from the green selection ("Current background/…").
Current Background=57,57,57
Current Foreground=244,244,244
# Active panel's bottom status line = the same green. Read by ListPanelFrame
# INDEPENDENT of "KDE Default"; only the ACTIVE panel, inactive stays neutral.
Statusbar Background Active=25,128,56
Statusbar Foreground Active=244,244,244
