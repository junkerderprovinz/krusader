# Default KDE-Settings für das Krusader-Image
# Wird von init-krusader bei JEDEM Start nach /config/.config/kdeglobals
# UND /config/.config/kdedefaults/kdeglobals ausgerollt.
#
# Das libkdeplatformtheme.so (aus plasma-integration) liest dieses File
# direkt und erkennt darueber den ColorScheme-Namen "BreezeDark", den es
# dann in /usr/share/color-schemes/BreezeDark.colors aufloest.

[General]
ColorScheme=BreezeDark
Name=Breeze Dark
shadeSortColumn=true
widgetStyle=Breeze
fixed=Noto Mono,10,-1,5,50,0,0,0,0,0
font=Noto Sans,10,-1,5,50,0,0,0,0,0
menuFont=Noto Sans,10,-1,5,50,0,0,0,0,0
smallestReadableFont=Noto Sans,8,-1,5,50,0,0,0,0,0
toolBarFont=Noto Sans,10,-1,5,50,0,0,0,0,0

[KDE]
ColorScheme=BreezeDark
LookAndFeelPackage=org.kde.breezedark.desktop
SingleClick=false
contrast=4
widgetStyle=Breeze

[Icons]
Theme=breeze-dark
