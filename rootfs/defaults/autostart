#!/bin/sh
# -----------------------------------------------------------------------------
# Krusader autostart fuer linuxserver/baseimage-selkies
# -----------------------------------------------------------------------------
# ACHTUNG POSIX: openbox fuehrt dieses Skript mit /bin/sh (dash) aus und
# IGNORIERT den Shebang — Bashismen wie [[ ]] schlagen still fehl ("[[: not
# found", Block wird uebersprungen) waehrend der Rest weiterlaeuft. Genau so
# wurde der Sprach-Block ausgehebelt (LANG blieb C.UTF-8). NUR POSIX-sh hier.
#
# Wird beim ersten Start nach /config/.config/openbox/autostart kopiert
# (durch init-selkies-config). Bei jedem weiteren Start ueberschreibt
# init-krusader dieses File, damit unsere ENV/Theme-Aenderungen ankommen.
#
# Theme-ENV werden primaer ueber /run/s6/container_environment gesetzt.
# Hier exportieren wir sie nochmal als Fallback, damit Krusader sie auch
# erhaelt, wenn das Skript ueber Pfade gestartet wird, die with-contenv
# umgehen.
# -----------------------------------------------------------------------------

# --- KDE-Plattform aktivieren (Hauptmechanismus) -----------------------------
# Dies laedt das libkdeplatformtheme.so aus plasma-integration -> KDE-Apps
# wie Krusader/Kate lesen kdeglobals ([Icons] Theme, [Colors:*]) nativ.
# UNBEDINGT unconditional: die Session erbt das Docker-ENV
# QT_QPA_PLATFORMTHEME=qt5ct (s6-Env kommt hier nicht an, ground truth) — ein
# ":-kde"-Fallback wuerde qt5ct BEHALTEN, das KDE-Plugin bliebe ungeladen und
# kdeglobals (Icon-Theme-Switch!) wuerde ignoriert. Es ist unsere Session, es
# gibt keinen legitimen Fremdwert, den wir respektieren muessten.
export QT_QPA_PLATFORMTHEME="kde"
export XDG_CURRENT_DESKTOP="KDE"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-KDE}"
export DESKTOP_SESSION="${DESKTOP_SESSION:-plasma}"

# --- Qt-Style + Color-Scheme -------------------------------------------------
export QT_STYLE_OVERRIDE="${QT_STYLE_OVERRIDE:-Breeze}"
export QT_AUTO_SCREEN_SCALE_FACTOR="${QT_AUTO_SCREEN_SCALE_FACTOR:-1}"
export KDE_COLOR_SCHEME_PATH="${KDE_COLOR_SCHEME_PATH:-/usr/share/color-schemes/DarkMode.colors}"

# Fallback-Suchpfad
if [ ! -f "$KDE_COLOR_SCHEME_PATH" ] && [ -f "$HOME/.local/share/color-schemes/DarkMode.colors" ]; then
    export KDE_COLOR_SCHEME_PATH="$HOME/.local/share/color-schemes/DarkMode.colors"
fi

# --- GTK-Apps & Cursor -------------------------------------------------------
export GTK_THEME="${GTK_THEME:-Breeze-Dark}"
export XCURSOR_THEME="${XCURSOR_THEME:-breeze_cursors}"

# --- Locale (von krusader-language.sh) ---------------------------------------
# Die Desktop-Session der Selkies-Base uebernimmt die s6-container_environment-
# Werte NICHT (die laufende App hatte LANG=C.UTF-8/LANGUAGE=en_US trotz
# korrektem s6-Env) — darum sourcen wir das Sprach-Snippet HIER, direkt vor dem
# Session-Start: das ueberschreibt die englischen Image-Defaults zuverlaessig
# fuer jede PUID. Bei KRUSADER_LANG=system existiert kein Snippet -> Fallbacks.
if [ -f /config/.profile.d/krusader-lang.sh ]; then
    # shellcheck disable=SC1091
    . /config/.profile.d/krusader-lang.sh
    echo "[krusader-autostart] language snippet sourced: LANG=$LANG LANGUAGE=$LANGUAGE" >&2
fi
export LANG="${LANG:-en_US.UTF-8}"
export LANGUAGE="${LANGUAGE:-en_US:en}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# --- XDG base dirs: pin to the persistent /config paths for EVERY PUID --------
# Under PUID=0 the session runs as literal root (LSIO cannot remap abc onto uid
# 0), whose default $HOME/.{config,cache,local/share} differ from abc's /config
# tree — so config, the KSycoca cache and file-type associations would land
# where the running Krusader does not read them (Issue #22). Pin them to the
# persistent /config locations so root and non-root behave identically, and make
# sure /usr/share/applications (Kate's .desktop) stays on the scan path so
# "Open With" and the mimeapps.list default resolve.
export XDG_CONFIG_HOME="/config/.config"
export XDG_DATA_HOME="/config/.local/share"
export XDG_CACHE_HOME="/config/.cache"
case ":${XDG_DATA_DIRS:-}:" in
    *":/usr/share:"*) : ;;
    *) export XDG_DATA_DIRS="${XDG_DATA_DIRS:+$XDG_DATA_DIRS:}/usr/local/share:/usr/share" ;;
esac
echo "[krusader-autostart] XDG pinned: CONFIG=$XDG_CONFIG_HOME CACHE=$XDG_CACHE_HOME DATA_DIRS=$XDG_DATA_DIRS" >&2

# --- Diagnose-Log ------------------------------------------------------------
echo "[krusader-autostart] QT_QPA_PLATFORMTHEME=$QT_QPA_PLATFORMTHEME" >&2
echo "[krusader-autostart] XDG_CURRENT_DESKTOP=$XDG_CURRENT_DESKTOP" >&2
echo "[krusader-autostart] QT_STYLE_OVERRIDE=$QT_STYLE_OVERRIDE" >&2
echo "[krusader-autostart] KDE_COLOR_SCHEME_PATH=$KDE_COLOR_SCHEME_PATH" >&2
echo "[krusader-autostart] GTK_THEME=$GTK_THEME" >&2
echo "[krusader-autostart] LANG=$LANG" >&2

# --- Start -------------------------------------------------------------------
# dbus-launch fuer KIO-Slaves (krarc, file, smb, ...). Auf der Selkies-Base
# wrappt startwm.sh openbox bereits in dbus-launch (aeusserer Session-Bus);
# unser innerer Bus ist damit verschachtelt - bewusst beibehalten (bewaehrt),
# Boxtest beobachtet Doppel-kded/KIO-Effekte.
# krusader-session startet ksmserver VOR krusader im selben D-Bus-Kontext,
# damit KDE-State-Persistenz (Bug #1) und Kate-Close-Events (Bug #2) funktionieren.
exec dbus-launch --exit-with-session krusader-session
