        },
        "String": {
            "text-color": "#a8a8a8",
            "selected-text-color": "#f4f4f4"
        },
        "VerbatimString": {
            "text-color": "#a8a8a8",
            "selected-text-color": "#f4f4f4"
        },
        "SpecialString": {
            "text-color": "#a8a8a8",
            "selected-text-color": "#f4f4f4"
        },
        "Import": {
            "text-color": "#8d8d8d",
            "selected-text-color": "#f4f4f4"
        },
        "DataType": {
            "text-color": "#c6c6c6",
