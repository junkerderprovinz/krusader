        },
        "Constant": {
            "text-color": "#8d8d8d",
            "selected-text-color": "#f4f4f4"
        },
        "Comment": {
            "text-color": "#6f6f6f",
            "selected-text-color": "#8d8d8d",
            "italic": true
        },
        "Documentation": {
            "text-color": "#6f6f6f",
