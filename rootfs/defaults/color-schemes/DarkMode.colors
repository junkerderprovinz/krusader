# Dark Mode — monochrome IBM-Carbon greyscale (base #161616), NO colour accent.
# Selection/focus is a lighter grey (#525252); the only non-grey tones are the
# functional error/warning colours. House standard, see the vault note
# "Style Guide - Docker Container". Replaces the previous KDE colour scheme.
#
# NOTE: KDE matches the scheme by this file's BASENAME (DarkMode) — keep the
# [General] ColorScheme value and every reference as "DarkMode" (no space).

[ColorEffects:Disabled]
Color=31,31,31
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=1
IntensityAmount=0.1
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=true
Color=111,111,111
ColorAmount=0.025
ColorEffect=2
ContrastAmount=0.1
ContrastEffect=2
Enable=false
IntensityAmount=0
IntensityEffect=0

