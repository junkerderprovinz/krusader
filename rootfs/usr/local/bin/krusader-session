#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# krusader-session — KDE session starter (called by autostart via dbus-launch)
# -----------------------------------------------------------------------------
# Starts ksmserver BEFORE krusader so both share the same D-Bus session bus.
# ksmserver registers as org.kde.ksmserver and emits saveYourself on logout,
# which causes KMainWindow::saveAutoSaveSettings() to persist window geometry
# and panel state to krusaderrc (Bug #1 fix). The same session bus path also
# fixes Kate's close-event routing (Bug #2 fix).
#
# If ksmserver is not installed (image built without plasma-workspace) the
# script falls through and just starts krusader — no regression.
#
# Clean shutdown (UI-state persistence): krusader only writes its "Save settings
# on exit" state (statusbar/toolbar visibility, geometry) when it quits CLEANLY.
# `docker stop` kills the process before that happens, so a hidden statusbar
# re-appears on the next start (which re-applies [Startup] Show statusbar=true).
# To fix this we run krusader in the background and trap the shutdown signal,
# then quit krusader cleanly (kquitapp) so its exit-save runs before the kill.
# -----------------------------------------------------------------------------

if command -v ksmserver >/dev/null 2>&1; then
    echo "[krusader-session] starting ksmserver for D-Bus session management" >&2
    ksmserver --no-lockscreen 2>/dev/null &
    # Give ksmserver time to register on the session bus before krusader starts.
    sleep 0.5
fi

# -stylesheet collapses the bottom status bar (KrusaderStatus) to height 0.
# Krusader does not persist that bar's visibility (upstream design), so this is
# the only way to keep it hidden by default on every start. The rule targets
# only that one widget class, so the Breeze theme is otherwise untouched.
krusader -stylesheet /usr/local/share/krusader-hide-statusbar.qss "$@" &
KR_PID=$!

_save_and_quit() {
    echo "[krusader-session] shutdown — quitting krusader cleanly so it saves" >&2
    # Clean quit triggers krusader's aboutToQuit -> "Save settings on exit".
    kquitapp6 krusader 2>/dev/null \
        || kquitapp5 krusader 2>/dev/null \
        || qdbus6 org.kde.krusader /MainApplication quit 2>/dev/null \
        || qdbus   org.kde.krusader /MainApplication quit 2>/dev/null \
        || kill -TERM "${KR_PID}" 2>/dev/null
    wait "${KR_PID}" 2>/dev/null
    exit 0
}
trap _save_and_quit TERM INT HUP

wait "${KR_PID}"
